# UK FITNESS - Environment Variables
# Copy these keys from your Supabase Dashboard (Settings > API)

# The URL of your Supabase Project API (REST endpoint)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# The Public Anon API Key used to query tables within Row Level Security guidelines
VITE_SUPABASE_ANON_KEY=your-supabase-public-anon-key-here
